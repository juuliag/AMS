programa {
  funcao inicio() {
    inteiro valor1, valor2, valor3, total

    escreva("Digite o valor 1: ")
    leia(valor1)

    escreva("Digite o valor 2: ")
    leia(valor2)

    escreva("Digite o valor 3: ")
    leia(valor3)

    total=(valor1 * valor1 + valor2 * valor2 + valor3 * valor3)

    escreva("Soma: ", total)
  }
}
